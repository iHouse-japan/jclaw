# ============================
# JClaw v2.5 Configuration
# ============================
# Dependency levels:
#   [REQUIRED] — JClaw will NOT start without these
#   [REQUIRED] — You need Ollama running with a model pulled
#   [OPTIONAL] — JClaw runs without these (features degrade gracefully)

# ─── REQUIRED: LINE Messaging API ───
# Get these from: https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# ─── REQUIRED: LLM Engine (Ollama) ───
# Install: https://ollama.com → ollama pull qwen3:14b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# ─── Server ───
PORT=3001

# ─── OPTIONAL: Web Search (SearXNG) ───
# Without this: JClaw works but cannot search the web
# Setup: docker run -d -p 8899:8080 searxng/searxng
SEARXNG_URL=http://localhost:8899

# ─── OPTIONAL: Memory System (memclawz) ───
# Without this: JClaw works but has no long-term memory
# Requires: Qdrant + Neo4j + memclawz API
MEMCLAWZ_URL=http://localhost:3500

# ─── OPTIONAL: Owner Mode ───
# Restrict bot to a single LINE user
OWNER_ONLY=false
OWNER_USER_ID=

# ─── OPTIONAL: Google Workspace ───
# Without this: JClaw works but cannot read Gmail/Calendar/Drive/Tasks
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ─── OPTIONAL: Custom System Prompt ───
# SYSTEM_PROMPT=あなたは...
