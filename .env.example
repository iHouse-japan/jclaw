# LINE Messaging API (Required)
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Ollama - Local LLM (Required)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Server
PORT=3001

# SearXNG - Self-hosted Web Search (Optional, free & unlimited)
# Run: docker compose up -d searxng
SEARXNG_URL=http://localhost:8899

# memclawz - Tier S Memory System (Optional, free & self-hosted)
# See: https://github.com/yoniassia/memclawz
# Requires: Qdrant + Neo4j + memclawz API running on port 3500
MEMCLAWZ_URL=http://localhost:3500

# Owner-Only Mode (Optional)
# Set to 'true' to restrict bot to owner only
# Use /setowner command in LINE to set your userId
OWNER_ONLY=false
OWNER_USER_ID=

# System Prompt (Optional - customize your AI personality)
# SYSTEM_PROMPT=あなたは...
